API_KEY=
BASE_URL=
MODEL=
# API_MODE: responses / chat (default responses)
API_MODE=responses
# Optional request timeout (seconds)
REQUEST_TIMEOUT=45
# Optional retry policy for network jitter / 429 / 5xx
REQUEST_MAX_RETRIES=2
REQUEST_RETRY_BACKOFF_MS=500

# Optional: OpenTelemetry switch (console exporter by default)
OTEL_ENABLED=false

# Optional: JSONL log sink path
LOG_FILE=observability/events.jsonl

# Optional: runtime tool whitelist (comma-separated). Use * to allow all.
ALLOWED_TOOLS=search_notes,list_note_files

# Optional: model-level reranker (P1). If disabled, falls back to rule reranker.
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-base

# Optional: image-text multimodal embedding model (for image vector index)
# e.g. clip-ViT-B-32
IMAGE_EMBEDDING_MODEL=clip-ViT-B-32

# Optional: VLM model for image understanding/captioning into note resources
# defaults to MODEL if omitted
VISION_MODEL=gpt-5.3-codex

# Optional: use multimodal LLM to parse image semantic content into text notes
ENABLE_IMAGE_VLM=true

# Optional: OCR switch for turning image content into searchable text notes
# true / false
ENABLE_IMAGE_OCR=true

# Optional: used to protect password/account queries in search_notes tool.
# Fill this with a bcrypt hash (recommended) or SHA256 hash (backward-compatible).
# bcrypt example:
#   python -c "import bcrypt;print(bcrypt.hashpw(b'your-key', bcrypt.gensalt()).decode())"
# Example (PowerShell):
#   "your-key" | python -c "import sys,hashlib;print(hashlib.sha256(sys.stdin.read().strip().encode()).hexdigest())"
SECURITY_KEY_HASH=

# Optional: sensitive query limit per minute (for password/account related requests)
SENSITIVE_QUERY_LIMIT_PER_MINUTE=3